{
    "symbol": "NVDA",
    "start_date": "2015-01-01",
    "end_date": "2026-01-01",

    "paths": {
        "raw_dir": "data_storage/raw",
        "processed_dir": "data_storage/processed"
    },

    "features": {
        "ma_windows": [5, 20, 60],
        "volatility_window": 20,
        "momentum_window": 5
    },

    "split": {
        "train_ratio": 0.70,
        "val_ratio": 0.15,
        "test_ratio": 0.15
    },

    "portfolio": {
        "initial_cash": 10000,
        "transaction_cost": 0.001
    },

    "experiment": {
        "seeds": [1, 2, 3],
        "noise_levels": [0.0, 0.05, 0.1, 0.3],
        "train_timesteps": 100000
    }
}
